{
    "datasource": {
        "oss": {
            "name": "oss_balenciaga",
            "bucket": "kering-balenciaga-data",
            "endpoint": "https://oss-cn-shanghai-internal.aliyuncs.com"
        },
        "mc": {
            "name": "odps_balenciaga",
            "project": "balenciaga_mc_project",
            "endpoint": "http://service.cn-shanghai.maxcompute.aliyun.com/api"
        }
    },
    "task": {
        "node_name": "balenciaga_integration_task",
        "cron": "00 00 03 * * ?",
        "reader_datasource": "oss_balenciaga",
        "reader_path": "data/export/*.csv",
        "writer_datasource": "odps_balenciaga",
        "writer_table": "Item",
        "writer_partition": "pt='${bizdate}'",
        "reader_prefix": "camos/guest_feature/",
        "mc_partition_retention": 30
    }
}